// Prisma schema covering phase 1 core plus fixed assets and loans/treasury

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/// Common enums
enum JournalType {
  GENERAL
  SALES
  PURCHASE
  CASH
  BANK
}

enum VoucherType {
  PAYMENT
  RECEIPT
  CONTRA
}

enum PaymentVoucherType {
  VENDOR_PAYMENT
  EXPENSE_PAYMENT
  STAFF_REIMBURSEMENT
  ADVANCE_PAYMENT
  PREPAYMENT
  REFUND
  TAX_REMITTANCE
  INTERCOMPANY_PAYMENT
  BANK_TRANSFER
  CASH_PAYMENT
}

enum PaymentVoucherSourceType {
  MANUAL
  VENDOR_BILL
  EXPENSE_CLAIM
  PAYROLL
  TAX
  SYSTEM
}

enum PaymentBeneficiaryType {
  VENDOR
  EMPLOYEE
  CUSTOMER
  TAX_AUTHORITY
  BANK
  OTHER
}

enum PaymentMethod {
  BANK_TRANSFER
  CHEQUE
  CASH
  CARD
  GATEWAY
  WALLET
}

enum PaymentVoucherStatus {
  DRAFT
  PENDING_APPROVAL
  PARTIALLY_APPROVED
  APPROVED
  REJECTED
  CANCELLED
  POSTED
  PAID
  FAILED_PAYMENT
  REVERSED
}

enum PaymentWorkflowStatus {
  AWAITING_SUBMISSION
  AWAITING_LEVEL_1_APPROVAL
  AWAITING_LEVEL_2_APPROVAL
  AWAITING_FINAL_APPROVAL
  APPROVED
  REJECTED
  RETURNED_FOR_CORRECTION
}

enum PaymentExecutionStatus {
  NOT_PAID
  PAYMENT_INITIATED
  PAYMENT_PROCESSING
  PAID
  FAILED
  REVERSED
}

enum PaymentLineType {
  INVOICE_SETTLEMENT
  EXPENSE
  TAX
  WITHHOLDING
  ADVANCE
  ADJUSTMENT
}

enum PaymentApprovalAction {
  SUBMITTED
  APPROVED
  REJECTED
  RETURNED
  RECALLED
  DELEGATED
  POSTED
  PAID
  CANCELLED
}

enum PaymentCommentType {
  INTERNAL
  APPROVAL
  REJECTION
  TREASURY
}

enum PaymentEventType {
  INITIATED
  PROCESSING
  CONFIRMED
  FAILED
  RETRIED
  REVERSED
  MANUAL_MARKED_PAID
  VERIFIED
}

enum PaymentTemplateKind {
  STANDARD_CORPORATE
  FINANCE_TREASURY
  CLEAN_A4
}

enum CustomerReceiptStatus {
  DRAFT
  POSTED
  CANCELLED
}

enum GLJournalType {
  MANUAL
  ADJUSTMENT
  ACCRUAL
  REVERSAL
  OPENING_BALANCE
  RECURRING
  ALLOCATION
  RECLASSIFICATION
  SYSTEM
}

enum GLJournalSourceType {
  MANUAL
  SALES
  PROCUREMENT
  PAYROLL
  ASSETS
  INVENTORY
  SYSTEM
}

enum GLSubledgerType {
  CUSTOMER
  VENDOR
  EMPLOYEE
  BANK
  ASSET
}

enum GLJournalStatus {
  DRAFT
  PENDING_APPROVAL
  APPROVED
  REJECTED
  POSTED
  REVERSED
  CANCELLED
}

enum GLApprovalAction {
  SUBMITTED
  APPROVED
  REJECTED
  RECALLED
  ESCALATED
  DELEGATED
  POSTED
  REVERSED
  CANCELLED
}

enum RecurringFrequency {
  DAILY
  WEEKLY
  MONTHLY
  QUARTERLY
  YEARLY
}

enum AssetStatus {
  ACTIVE
  TRANSFERRED
  DISPOSED
  IMPAIRED
}

enum DepreciationMethod {
  STRAIGHT_LINE
  DECLINING_BALANCE
  UNITS_OF_PRODUCTION
}

enum LoanType {
  TERM
  REVOLVING
}

enum ScheduleType {
  ANNUITY
  INTEREST_ONLY
  BALLOON
  CUSTOM
}

enum FinancialStatementCategory {
  REVENUE
  COST_OF_SALES
  OTHER_INCOME
  OPERATING_EXPENSE
  DEPRECIATION_AND_AMORTIZATION
  FINANCE_INCOME
  FINANCE_COST
  INCOME_TAX
  OTHER_COMPREHENSIVE_INCOME
  ASSET_CURRENT
  INVENTORY
  RECEIVABLE
  CASH_AND_EQUIVALENT
  ASSET_NONCURRENT
  LIABILITY_CURRENT
  LIABILITY_NONCURRENT
  EQUITY_SHARE_CAPITAL
  EQUITY_RETAINED_EARNINGS
  EQUITY_RESERVE
  DIVIDEND
}

/// System
model User {
  id            Int            @id @default(autoincrement())
  email         String         @unique
  passwordHash  String
  firstName     String?
  lastName      String?
  isActive      Boolean        @default(true)
  isLocked      Boolean        @default(false)
  roles         UserRole[]
  sessions      Session[]
  auditLogs     AuditLog[]
  postingAudits PostingAudit[]
  refreshTokens RefreshToken[]
  loginAttempts LoginAttempt[]
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  Notification  Notification[]
}

model Role {
  id          Int              @id @default(autoincrement())
  name        String           @unique
  description String?
  users       UserRole[]
  permissions RolePermission[]
}

model Permission {
  id          Int              @id @default(autoincrement())
  code        String           @unique
  description String?
  roles       RolePermission[]
}

model UserRole {
  userId Int
  roleId Int
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)
  role   Role @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([userId, roleId])
}

model RolePermission {
  roleId       Int
  permissionId Int
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
}

model Session {
  id        Int      @id @default(autoincrement())
  token     String   @unique
  userId    Int
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  expiresAt DateTime
}

model RefreshToken {
  id              Int      @id @default(autoincrement())
  tokenHash       String   @unique
  familyId        String?  // Groups tokens from the same login session
  replacedByHash  String?  // Hash of the next token in the chain (set on rotation)
  userId          Int
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt       DateTime
  createdAt       DateTime @default(now())

  @@index([userId, expiresAt], name: "idx_refresh_token_user_expiry")
  @@index([familyId], name: "idx_refresh_token_family")
}

model LoginAttempt {
  id          Int      @id @default(autoincrement())
  userId       Int?
  user         User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  ipAddress    String
  attemptedAt  DateTime @default(now())

  @@index([userId, attemptedAt], name: "idx_login_attempt_user_time")
  @@index([ipAddress, attemptedAt], name: "idx_login_attempt_ip_time")
}

model AuditLog {
  id         Int      @id @default(autoincrement())
  userId     Int?
  user       User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  role       String?
  action     String
  resourceId String?
  entity     String?
  entityId   String?
  ipAddress  String?
  meta       Json?
  timestamp  DateTime @default(now())
  createdAt  DateTime @default(now())

  @@index([userId, timestamp], name: "idx_audit_log_user_time")
  @@index([action, timestamp], name: "idx_audit_log_action_time")
}

/// Organization
model Company {
  id                        Int                          @id @default(autoincrement())
  name                      String
  legalName                 String?
  code                      String?                      @unique
  registrationNumber        String?
  taxId                     String?
  email                     String?
  phone                     String?
  addressLine1              String?
  addressLine2              String?
  city                      String?
  state                     String?
  country                   String?
  logoUrl                   String?
  currencyId                Int?
  timezone                  String?
  fiscalYearStartMonth      Int?                         @default(1)
  isActive                  Boolean                      @default(true)
  useBranches               Boolean                      @default(true)
  useInventory              Boolean                      @default(true)
  usePayroll                Boolean                      @default(false)
  useDepartments            Boolean                      @default(true)
  branches                  Branch[]
  departments               Department[]
  sequences                 NumberingSequence[]
  accountingPeriods         AccountingPeriod[]
  fiscalYears               FiscalYear[]
  costCenters               CostCenter[]
  projects                  Project[]
  postingRules              PostingRule[]
  postingAudits             PostingAudit[]
  glJournals                GLJournalHeader[]
  recurringJournalTemplates GLRecurringJournalTemplate[]
  paymentVoucherHeaders     APPaymentVoucherHeader[]
  paymentTemplates          APPaymentTemplate[]
  customerReceipts          CustomerReceiptHeader[]
  customers                 Customer[]
  suppliers                 Supplier[]
  products                  Product[]
  salesInvoices             SalesInvoice[]
  purchaseBills             PurchaseBill[]
  bankAccounts              BankAccount[]
  createdAt                 DateTime                     @default(now())
  updatedAt                 DateTime                     @updatedAt
  currency                  Currency?                    @relation(fields: [currencyId], references: [id])
  TaxConfig                 TaxConfig[]
}

model Branch {
  id                         Int                              @id @default(autoincrement())
  name                       String
  code                       String                           @unique
  companyId                  Int
  company                    Company                          @relation(fields: [companyId], references: [id], onDelete: Cascade)
  warehouses                 Warehouse[]
  createdAt                  DateTime                         @default(now())
  updatedAt                  DateTime                         @updatedAt
  JournalLine                JournalLine[]
  Asset                      Asset[]
  PostingRule                PostingRule[]
  PostingAudit               PostingAudit[]
  glJournals                 GLJournalHeader[]
  glJournalLines             GLJournalLine[]
  recurringTemplateLines     GLRecurringJournalTemplateLine[]
  GLRecurringJournalTemplate GLRecurringJournalTemplate[]
  paymentVoucherHeaders      APPaymentVoucherHeader[]
  paymentVoucherLines        APPaymentVoucherLine[]
  paymentTemplates           APPaymentTemplate[]
  customerReceipts           CustomerReceiptHeader[]
  bankAccounts               BankAccount[]
}

model Department {
  id                        Int                              @id @default(autoincrement())
  name                      String
  companyId                 Int
  company                   Company                          @relation(fields: [companyId], references: [id], onDelete: Cascade)
  createdAt                 DateTime                         @default(now())
  updatedAt                 DateTime                         @updatedAt
  postingRules              PostingRule[]
  glJournals                GLJournalHeader[]
  glJournalLines            GLJournalLine[]
  recurringJournalTemplates GLRecurringJournalTemplate[]
  recurringTemplateLines    GLRecurringJournalTemplateLine[]
  paymentVoucherHeaders     APPaymentVoucherHeader[]
  paymentVoucherLines       APPaymentVoucherLine[]
}

model FiscalYear {
  id         Int                @id @default(autoincrement())
  companyId  Int
  name       String
  startDate  DateTime
  endDate    DateTime
  status     String             @default("OPEN")
  createdAt  DateTime           @default(now())
  updatedAt  DateTime           @updatedAt
  company    Company            @relation(fields: [companyId], references: [id], onDelete: Cascade)
  periods    AccountingPeriod[]
  glJournals GLJournalHeader[]
  paymentVoucherHeaders APPaymentVoucherHeader[]

  @@unique([companyId, name])
}

model CostCenter {
  id                        Int                              @id @default(autoincrement())
  companyId                 Int
  code                      String
  name                      String
  isActive                  Boolean                          @default(true)
  createdAt                 DateTime                         @default(now())
  updatedAt                 DateTime                         @updatedAt
  company                   Company                          @relation(fields: [companyId], references: [id], onDelete: Cascade)
  glJournals                GLJournalHeader[]
  glJournalLines            GLJournalLine[]
  recurringJournalTemplates GLRecurringJournalTemplate[]
  recurringTemplateLines    GLRecurringJournalTemplateLine[]
  paymentVoucherHeaders     APPaymentVoucherHeader[]
  paymentVoucherLines       APPaymentVoucherLine[]

  @@unique([companyId, code])
}

model Project {
  id                        Int                              @id @default(autoincrement())
  companyId                 Int
  code                      String
  name                      String
  isActive                  Boolean                          @default(true)
  createdAt                 DateTime                         @default(now())
  updatedAt                 DateTime                         @updatedAt
  company                   Company                          @relation(fields: [companyId], references: [id], onDelete: Cascade)
  glJournals                GLJournalHeader[]
  glJournalLines            GLJournalLine[]
  recurringJournalTemplates GLRecurringJournalTemplate[]
  recurringTemplateLines    GLRecurringJournalTemplateLine[]
  paymentVoucherHeaders     APPaymentVoucherHeader[]
  paymentVoucherLines       APPaymentVoucherLine[]

  @@unique([companyId, code])
}

model Currency {
  id          Int           @id @default(autoincrement())
  code        String        @unique
  name        String
  symbol      String?
  createdAt   DateTime      @default(now())
  Company     Company[]
  BankAccount BankAccount[]
  Loan        Loan[]
}

model TaxConfig {
  id                     Int                              @id @default(autoincrement())
  code                   String
  name                   String
  taxType                String                           @default("VAT")
  rate                   Decimal                          @db.Decimal(10, 4)
  isInclusive            Boolean                          @default(false)
  recoverable            Boolean                          @default(false)
  filingFrequency        String                           @default("MONTHLY")
  companyId              Int
  outputAccountId        Int?
  inputAccountId         Int?
  liabilityAccountId     Int?
  company                Company                          @relation(fields: [companyId], references: [id], onDelete: Cascade)
  outputAccount          Account?                         @relation("TaxConfigOutputAccount", fields: [outputAccountId], references: [id])
  inputAccount           Account?                         @relation("TaxConfigInputAccount", fields: [inputAccountId], references: [id])
  liabilityAccount       Account?                         @relation("TaxConfigLiabilityAccount", fields: [liabilityAccountId], references: [id])
  glJournalLines         GLJournalLine[]
  recurringTemplateLines GLRecurringJournalTemplateLine[]
  paymentVoucherTaxLines APPaymentVoucherLine[]          @relation("PaymentVoucherTaxCode")
  paymentVoucherWithholdingLines APPaymentVoucherLine[]  @relation("PaymentVoucherWithholdingTaxCode")
  createdAt              DateTime                         @default(now())
  updatedAt              DateTime                         @updatedAt

  @@unique([companyId, code])
}

model NumberingSequence {
  id         Int      @id @default(autoincrement())
  name       String
  prefix     String?
  nextNumber Int      @default(1)
  companyId  Int
  company    Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

/// Accounting
model Account {
  id                              Int                              @id @default(autoincrement())
  code                            String                           @unique
  name                            String
  type                            String // e.g., ASSET, LIABILITY, EQUITY, INCOME, EXPENSE
  financialStatementCategory      FinancialStatementCategory?
  description                     String?
  parentId                        Int?
  parent                          Account?                         @relation("AccountToAccount", fields: [parentId], references: [id])
  children                        Account[]                        @relation("AccountToAccount")
  isActive                        Boolean                          @default(true)
  allowsPosting                   Boolean                          @default(true)
  allowsManualPosting             Boolean                          @default(true)
  isControlAccount                Boolean                          @default(false)
  controlSource                   String?
  requiresSubledger               Boolean                          @default(false)
  requiresDepartment              Boolean                          @default(false)
  requiresCostCenter              Boolean                          @default(false)
  requiresProject                 Boolean                          @default(false)
  requiresTax                     Boolean                          @default(false)
  createdAt                       DateTime                         @default(now())
  updatedAt                       DateTime                         @updatedAt
  JournalLine                     JournalLine[]
  glJournalLines                  GLJournalLine[]
  recurringTemplateLines          GLRecurringJournalTemplateLine[]
  PostingRuleDebitAccounts        PostingRule[]                    @relation("PostingRuleDebitAccount")
  PostingRuleCreditAccounts       PostingRule[]                    @relation("PostingRuleCreditAccount")
  PostingRuleTaxAccounts          PostingRule[]                    @relation("PostingRuleTaxAccount")
  PostingRuleRoundingAccounts     PostingRule[]                    @relation("PostingRuleRoundingAccount")
  PostingRuleExchangeGainAccounts PostingRule[]                    @relation("PostingRuleExchangeGainAccount")
  PostingRuleExchangeLossAccounts PostingRule[]                    @relation("PostingRuleExchangeLossAccount")
  PostingRuleSuspenseAccounts     PostingRule[]                    @relation("PostingRuleSuspenseAccount")
  TaxConfigOutputAccounts         TaxConfig[]                      @relation("TaxConfigOutputAccount")
  TaxConfigInputAccounts          TaxConfig[]                      @relation("TaxConfigInputAccount")
  TaxConfigLiabilityAccounts      TaxConfig[]                      @relation("TaxConfigLiabilityAccount")
  paymentVoucherPayableAccounts   APPaymentVoucherHeader[]         @relation("PaymentVoucherPayableAccount")
  paymentVoucherCashAccounts      APPaymentVoucherHeader[]         @relation("PaymentVoucherCashAccount")
  paymentVoucherLineAccounts      APPaymentVoucherLine[]
  paymentTemplatesDefaultAccounts APPaymentTemplate[]              @relation("PaymentTemplateDefaultAccount")
  bankAccountGlAccounts           BankAccount[]                    @relation("BankAccountGLAccount")
  customerReceiptCashAccounts     CustomerReceiptHeader[]          @relation("CustomerReceiptCashAccount")
  customerReceiptReceivableAccounts CustomerReceiptHeader[]        @relation("CustomerReceiptReceivableAccount")
}

model JournalEntry {
  id              Int              @id @default(autoincrement())
  reference       String           @unique
  type            JournalType      @default(GENERAL)
  description     String?
  date            DateTime
  lines           JournalLine[]
  createdAt       DateTime         @default(now())
  createdBy       Int?
  updatedAt       DateTime         @updatedAt
  Voucher         Voucher[]
  postingAudit    PostingAudit?
  glJournalHeader GLJournalHeader?
  paymentVouchers APPaymentVoucherHeader[]
  customerReceipts CustomerReceiptHeader[]
}

model JournalLine {
  id        Int          @id @default(autoincrement())
  entryId   Int
  accountId Int
  branchId  Int?
  debit     Decimal      @default(0) @db.Decimal(18, 2)
  credit    Decimal      @default(0) @db.Decimal(18, 2)
  memo      String?
  entry     JournalEntry @relation(fields: [entryId], references: [id], onDelete: Cascade)
  account   Account      @relation(fields: [accountId], references: [id])
  branch    Branch?      @relation(fields: [branchId], references: [id])

  @@index([entryId], name: "idx_journal_line_entry")
}

model Voucher {
  id        Int           @id @default(autoincrement())
  type      VoucherType
  reference String        @unique
  amount    Decimal       @db.Decimal(18, 2)
  date      DateTime
  payee     String?
  memo      String?
  journalId Int?
  journal   JournalEntry? @relation(fields: [journalId], references: [id])
  createdAt DateTime      @default(now())
}

model AccountingPeriod {
  id           Int               @id @default(autoincrement())
  name         String
  companyId    Int?
  fiscalYearId Int?
  startDate    DateTime
  endDate      DateTime
  status       String            @default("OPEN")
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt
  company      Company?          @relation(fields: [companyId], references: [id], onDelete: Cascade)
  fiscalYear   FiscalYear?       @relation(fields: [fiscalYearId], references: [id], onDelete: SetNull)
  glJournals   GLJournalHeader[]
  paymentVoucherHeaders APPaymentVoucherHeader[]

  @@index([companyId, startDate, endDate], name: "idx_accounting_period_company_dates")
}

model GLJournalHeader {
  id                    Int                         @id @default(autoincrement())
  journalNumber         String                      @unique
  journalType           GLJournalType
  sourceType            GLJournalSourceType         @default(MANUAL)
  sourceModule          String?
  sourceDocumentId      String?
  sourceDocumentNumber  String?
  legalEntityId         Int
  branchId              Int
  departmentId          Int?
  costCenterId          Int?
  projectId             Int?
  journalDate           DateTime
  postingDate           DateTime
  accountingPeriodId    Int
  fiscalYearId          Int?
  currencyCode          String
  exchangeRate          Decimal?                    @db.Decimal(18, 6)
  referenceNumber       String?
  externalReference     String?
  narration             String
  description           String?
  attachmentCount       Int                         @default(0)
  status                GLJournalStatus             @default(DRAFT)
  workflowStatus        String                      @default("DRAFT")
  approvalLevel         Int                         @default(0)
  createdBy             Int?
  createdAt             DateTime                    @default(now())
  updatedBy             Int?
  updatedAt             DateTime                    @updatedAt
  submittedBy           Int?
  submittedAt           DateTime?
  approvedBy            Int?
  approvedAt            DateTime?
  postedBy              Int?
  postedAt              DateTime?
  reversedBy            Int?
  reversedAt            DateTime?
  reversalOfJournalId   Int?
  reversalReason        String?
  isSystemGenerated     Boolean                     @default(false)
  isAutoReversing       Boolean                     @default(false)
  autoReverseDate       DateTime?
  isRecurring           Boolean                     @default(false)
  recurringTemplateId   Int?
  isIntercompany        Boolean                     @default(false)
  intercompanyReference String?
  idempotencyKey        String?                     @unique
  totalDebit            Decimal                     @default(0) @db.Decimal(18, 2)
  totalCredit           Decimal                     @default(0) @db.Decimal(18, 2)
  postedJournalEntryId  Int?                        @unique
  legalEntity           Company                     @relation(fields: [legalEntityId], references: [id], onDelete: Restrict)
  branch                Branch                      @relation(fields: [branchId], references: [id], onDelete: Restrict)
  department            Department?                 @relation(fields: [departmentId], references: [id], onDelete: SetNull)
  costCenter            CostCenter?                 @relation(fields: [costCenterId], references: [id], onDelete: SetNull)
  project               Project?                    @relation(fields: [projectId], references: [id], onDelete: SetNull)
  accountingPeriod      AccountingPeriod            @relation(fields: [accountingPeriodId], references: [id], onDelete: Restrict)
  fiscalYear            FiscalYear?                 @relation(fields: [fiscalYearId], references: [id], onDelete: SetNull)
  reversalOfJournal     GLJournalHeader?            @relation("GLJournalReversal", fields: [reversalOfJournalId], references: [id], onDelete: SetNull)
  reversalJournals      GLJournalHeader[]           @relation("GLJournalReversal")
  recurringTemplate     GLRecurringJournalTemplate? @relation(fields: [recurringTemplateId], references: [id], onDelete: SetNull)
  postedJournalEntry    JournalEntry?               @relation(fields: [postedJournalEntryId], references: [id], onDelete: SetNull)
  lines                 GLJournalLine[]
  attachments           GLJournalAttachment[]
  approvalHistory       GLJournalApprovalHistory[]
  auditLogs             GLJournalAuditLog[]
  statusHistory         GLJournalStatusHistory[]

  @@index([legalEntityId, branchId, journalDate], name: "idx_gl_journal_scope_dates")
  @@index([status, journalType, sourceType], name: "idx_gl_journal_status_type")
  @@index([sourceModule, sourceDocumentId], name: "idx_gl_journal_source")
}

model GLJournalLine {
  id                      Int              @id @default(autoincrement())
  journalId               Int
  lineNumber              Int
  accountId               Int
  accountCode             String
  accountName             String
  accountType             String
  subledgerType           GLSubledgerType?
  subledgerId             String?
  debitAmount             Decimal          @default(0) @db.Decimal(18, 2)
  creditAmount            Decimal          @default(0) @db.Decimal(18, 2)
  baseCurrencyDebit       Decimal?         @db.Decimal(18, 2)
  baseCurrencyCredit      Decimal?         @db.Decimal(18, 2)
  transactionCurrencyCode String
  exchangeRate            Decimal?         @db.Decimal(18, 6)
  taxCodeId               Int?
  taxAmount               Decimal?         @db.Decimal(18, 2)
  branchId                Int?
  departmentId            Int?
  costCenterId            Int?
  projectId               Int?
  productId               Int?
  itemId                  String?
  warehouseId             Int?
  quantity                Decimal?         @db.Decimal(18, 3)
  unitOfMeasure           String?
  lineNarration           String?
  reference1              String?
  reference2              String?
  dueDate                 DateTime?
  partnerName             String?
  partnerCode             String?
  createdAt               DateTime         @default(now())
  updatedAt               DateTime         @updatedAt
  journal                 GLJournalHeader  @relation(fields: [journalId], references: [id], onDelete: Cascade)
  account                 Account          @relation(fields: [accountId], references: [id], onDelete: Restrict)
  taxCode                 TaxConfig?       @relation(fields: [taxCodeId], references: [id], onDelete: SetNull)
  branch                  Branch?          @relation(fields: [branchId], references: [id], onDelete: SetNull)
  department              Department?      @relation(fields: [departmentId], references: [id], onDelete: SetNull)
  costCenter              CostCenter?      @relation(fields: [costCenterId], references: [id], onDelete: SetNull)
  project                 Project?         @relation(fields: [projectId], references: [id], onDelete: SetNull)
  product                 Product?         @relation(fields: [productId], references: [id], onDelete: SetNull)
  warehouse               Warehouse?       @relation(fields: [warehouseId], references: [id], onDelete: SetNull)

  @@unique([journalId, lineNumber])
  @@index([accountId], name: "idx_gl_journal_line_account")
  @@index([branchId, departmentId, costCenterId, projectId], name: "idx_gl_journal_line_dimensions")
}

model GLJournalAttachment {
  id         Int             @id @default(autoincrement())
  journalId  Int
  fileName   String
  fileUrl    String
  mimeType   String?
  uploadedBy Int?
  uploadedAt DateTime        @default(now())
  journal    GLJournalHeader @relation(fields: [journalId], references: [id], onDelete: Cascade)
}

model GLJournalApprovalHistory {
  id              Int              @id @default(autoincrement())
  journalId       Int
  action          GLApprovalAction
  approvalLevel   Int              @default(0)
  actorUserId     Int?
  actorName       String?
  comments        String?
  rejectionReason String?
  delegatedTo     String?
  actedAt         DateTime         @default(now())
