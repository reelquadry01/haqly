  id                  Int                   @id @default(autoincrement())
  receiptNumber       String                @unique
  legalEntityId       Int
  branchId            Int
  customerId          Int
  bankAccountId       Int?
  cashAccountId       Int?
  receivableAccountId Int
  paymentMethod       PaymentMethod
  paymentDate         DateTime
  postingDate         DateTime
  currencyCode        String
  exchangeRate        Decimal?              @db.Decimal(18, 6)
  amount              Decimal               @db.Decimal(18, 2)
  bankReference       String?
  externalReference   String?
  narration           String
  remarks             String?
  status              CustomerReceiptStatus @default(DRAFT)
  attachmentCount     Int                   @default(0)
  createdBy           Int?
  createdAt           DateTime              @default(now())
  updatedAt           DateTime              @updatedAt
  postedBy            Int?
  postedAt            DateTime?
  glJournalId         Int?
  legalEntity         Company               @relation(fields: [legalEntityId], references: [id], onDelete: Cascade)
  branch              Branch                @relation(fields: [branchId], references: [id], onDelete: Cascade)
  customer            Customer              @relation(fields: [customerId], references: [id], onDelete: Restrict)
  bankAccount         BankAccount?          @relation(fields: [bankAccountId], references: [id], onDelete: SetNull)
  cashAccount         Account?              @relation("CustomerReceiptCashAccount", fields: [cashAccountId], references: [id], onDelete: SetNull)
  receivableAccount   Account               @relation("CustomerReceiptReceivableAccount", fields: [receivableAccountId], references: [id], onDelete: Restrict)
  glJournal           JournalEntry?         @relation(fields: [glJournalId], references: [id], onDelete: SetNull)
  lines               CustomerReceiptLine[]

  @@index([legalEntityId, branchId, paymentDate], name: "idx_customer_receipt_scope_date")
  @@index([customerId, status], name: "idx_customer_receipt_customer_status")
}

model CustomerReceiptLine {
  id          Int                  @id @default(autoincrement())
  receiptId   Int
  lineNumber  Int
  invoiceId   Int?
  description String
  appliedAmount Decimal            @db.Decimal(18, 2)
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt
  receipt     CustomerReceiptHeader @relation(fields: [receiptId], references: [id], onDelete: Cascade)
  invoice     SalesInvoice?        @relation(fields: [invoiceId], references: [id], onDelete: SetNull)

  @@unique([receiptId, lineNumber])
  @@index([invoiceId], name: "idx_customer_receipt_line_invoice")
}

model SalesInvoiceItem {
  id        Int          @id @default(autoincrement())
  invoiceId Int
  productId Int
  quantity  Decimal      @db.Decimal(18, 3)
  unitPrice Decimal      @db.Decimal(18, 2)
  taxRate   Decimal?     @db.Decimal(10, 4)
  invoice   SalesInvoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  product   Product      @relation(fields: [productId], references: [id])
}

model PurchaseBill {
  id           Int                @id @default(autoincrement())
  number       String             @unique
  legalEntityId Int?
  supplierId   Int
  date         DateTime
  dueDate      DateTime?
  status       String
  total        Decimal            @db.Decimal(18, 2)
  items        PurchaseBillItem[]
  legalEntity  Company?           @relation(fields: [legalEntityId], references: [id], onDelete: Cascade)
  supplier     Supplier           @relation(fields: [supplierId], references: [id])
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt

  @@index([legalEntityId, date], name: "idx_purchase_bill_company_date")
}

model PurchaseBillItem {
  id        Int          @id @default(autoincrement())
  billId    Int
  productId Int
  quantity  Decimal      @db.Decimal(18, 3)
  unitCost  Decimal      @db.Decimal(18, 2)
  taxRate   Decimal?     @db.Decimal(10, 4)
  bill      PurchaseBill @relation(fields: [billId], references: [id], onDelete: Cascade)
  product   Product      @relation(fields: [productId], references: [id])
}

/// Fixed Assets & Depreciation
model AssetCategory {
  id                  Int                @id @default(autoincrement())
  name                String
  usefulLifeMonths    Int
  residualRate        Decimal            @default(0) @db.Decimal(5, 2)
  depreciationMethod  DepreciationMethod @default(STRAIGHT_LINE)
  glAssetAccountId    Int?
  glAccumDepAccountId Int?
  glExpenseAccountId  Int?
  assets              Asset[]
}

model Asset {
  id                Int                @id @default(autoincrement())
  tag               String             @unique
  name              String
  categoryId        Int
  branchId          Int?
  acquisitionDate   DateTime
  acquisitionCost   Decimal            @db.Decimal(18, 2)
  residualValue     Decimal            @default(0) @db.Decimal(18, 2)
  status            AssetStatus        @default(ACTIVE)
  depreciationStart DateTime?
  disposalDate      DateTime?
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  category          AssetCategory      @relation(fields: [categoryId], references: [id])
  branch            Branch?            @relation(fields: [branchId], references: [id])
  depreciationLines DepreciationLine[]
}

model DepreciationPolicy {
  id        Int                @id @default(autoincrement())
  name      String
  method    DepreciationMethod
  prorate   Boolean            @default(true)
  midMonth  Boolean            @default(false)
  companyId Int?
  createdAt DateTime           @default(now())
}

model DepreciationRun {
  id          Int                @id @default(autoincrement())
  periodStart DateTime
  periodEnd   DateTime
  book        String             @default("book")
  status      String             @default("POSTED") // PENDING, POSTED, ROLLED_BACK
  createdAt   DateTime           @default(now())
  lines       DepreciationLine[]
}

model DepreciationLine {
  id          Int             @id @default(autoincrement())
  runId       Int
  assetId     Int
  amount      Decimal         @db.Decimal(18, 2)
  accumulated Decimal         @db.Decimal(18, 2)
  periodStart DateTime
  periodEnd   DateTime
  run         DepreciationRun @relation(fields: [runId], references: [id], onDelete: Cascade)
  asset       Asset           @relation(fields: [assetId], references: [id])

  @@index([assetId], name: "idx_depr_line_asset")
}

/// Loans & Treasury
model Loan {
  id           Int            @id @default(autoincrement())
  code         String         @unique
  lender       String
  type         LoanType       @default(TERM)
  principal    Decimal        @db.Decimal(18, 2)
  currencyId   Int?
  startDate    DateTime
  endDate      DateTime?
  rateType     String // FIXED, VARIABLE
  baseRate     Decimal?       @db.Decimal(9, 4)
  spread       Decimal?       @db.Decimal(9, 4)
  scheduleType ScheduleType   @default(ANNUITY)
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  currency     Currency?      @relation(fields: [currencyId], references: [id])
  rates        LoanRate[]
  schedules    LoanSchedule[]
  payments     LoanPayment[]
}

model LoanRate {
  id        Int      @id @default(autoincrement())
  loanId    Int
  effective DateTime
  rate      Decimal  @db.Decimal(9, 4)
  loan      Loan     @relation(fields: [loanId], references: [id], onDelete: Cascade)
}

model LoanSchedule {
  id           Int           @id @default(autoincrement())
  loanId       Int
  installment  Int
  dueDate      DateTime
  principalDue Decimal       @db.Decimal(18, 2)
  interestDue  Decimal       @db.Decimal(18, 2)
  feesDue      Decimal       @default(0) @db.Decimal(18, 2)
  status       String        @default("PENDING")
  loan         Loan          @relation(fields: [loanId], references: [id], onDelete: Cascade)
  payments     LoanPayment[]

  @@index([loanId], name: "idx_loan_schedule_loan")
}

model LoanPayment {
  id            Int           @id @default(autoincrement())
  loanId        Int
  scheduleId    Int?
  paymentDate   DateTime
  principalPaid Decimal       @default(0) @db.Decimal(18, 2)
  interestPaid  Decimal       @default(0) @db.Decimal(18, 2)
  feesPaid      Decimal       @default(0) @db.Decimal(18, 2)
  memo          String?
  loan          Loan          @relation(fields: [loanId], references: [id], onDelete: Cascade)
  schedule      LoanSchedule? @relation(fields: [scheduleId], references: [id])
}

/// Notifications & Files
model NotificationTemplate {
  id           Int            @id @default(autoincrement())
  code         String         @unique
  subject      String
  body         String
  channel      String // EMAIL, SMS, IN_APP
  createdAt    DateTime       @default(now())
  Notification Notification[]
}

model Notification {
  id         Int                   @id @default(autoincrement())
  userId     Int?
  templateId Int?
  channel    String
  payload    Json?
  status     String                @default("PENDING")
  createdAt  DateTime              @default(now())
  sentAt     DateTime?
  user       User?                 @relation(fields: [userId], references: [id])
  template   NotificationTemplate? @relation(fields: [templateId], references: [id])
}

model FileAttachment {
  id        Int      @id @default(autoincrement())
  bucket    String
  key       String
  filename  String
  mimeType  String?
  size      Int?
  entity    String?
  entityId  String?
  createdAt DateTime @default(now())
}
